# Copia este archivo a ".env" en la raíz del proyecto y rellena los valores.
# No subas ".env" al repositorio.
#
# Uso:
#   flutter run --dart-define-from-file=.env
#
# En CI, define las mismas claves con --dart-define=CLAVE=valor (sin archivo).

# Stripe (obligatorio para pagos en app)
STRIPE_PUBLISHABLE_KEY=
# true = Cloud Function initStripePayment; false = initStripeTestPayment
STRIPE_USE_LIVE_BACKEND=true
# Apple Pay (iOS); opcional si no usas Apple Pay
STRIPE_APPLE_MERCHANT_ID=

# RevenueCat (por plataforma; vacío = esa plataforma no inicializa Purchases)
REVENUECAT_APPLE_API_KEY=
REVENUECAT_GOOGLE_API_KEY=
REVENUECAT_WEB_API_KEY=
